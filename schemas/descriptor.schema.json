{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://golden-magic.local/schemas/descriptor.schema.json",
  "title": "Golden Magic Descriptor",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$",
      "description": "Stable unique descriptor id."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable descriptor name."
    },
    "priority": {
      "type": "integer",
      "default": 0,
      "description": "Higher priority descriptors are selected first."
    },
    "matches": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_substrings": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "default": []
        }
      }
    },
    "parser": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["heuristic", "sections", "tree-sitter-rust", "executable-json"],
          "description": "Parser backend id."
        },
        "executable": {
          "type": "string",
          "minLength": 1,
          "description": "Path to an explicit executable parser plugin for executable-json backends. Relative paths resolve beside descriptor.toml."
        },
        "only_rules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true,
          "default": []
        },
        "disable_rules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true,
          "default": []
        }
      }
    }
  }
}
